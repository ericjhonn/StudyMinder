<UserControl x:Class="StudyMinder.Views.ViewComparadorEditais"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mah="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:controls="clr-namespace:StudyMinder.Controls"
             xmlns:converters="clr-namespace:StudyMinder.Converters"
             mc:Ignorable="d"
             d:DesignHeight="1200"
             d:DesignWidth="1000">

    <UserControl.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <Border Grid.Row="0"
                Style="{DynamicResource ViewHeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Comparador de Editais"
                           Style="{StaticResource Title1Style}" />
            </Grid>
        </Border>

        <!-- Comparador -->
        <Border Grid.Row="1"
                Style="{StaticResource PrimaryCardStyle}"
                Padding="20"
                Margin="20,20,20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox Grid.Column="0"
                          ItemsSource="{Binding ListaEditais}"
                          SelectedItem="{Binding EditalBaseSelecionado}"
                          Style="{StaticResource ModernComboBoxStyle}"
                          DisplayMemberPath="Nome"
                          Tag="Edital Base"
                          Margin="0"/>

                <mah:PackIconMaterial Grid.Column="1"
                                      Kind="CompareHorizontal"
                                      Width="24"
                                      Height="24"
                                      VerticalAlignment="Center"
                                      Margin="10,0"
                                      Foreground="{DynamicResource PrimaryBrush}" />

                <ComboBox Grid.Column="2"
                          ItemsSource="{Binding ListaEditais}"
                          SelectedItem="{Binding EditalAlvoSelecionado}"
                          DisplayMemberPath="Nome"
                          Style="{StaticResource ModernComboBoxStyle}"
                          Tag="Edital Alvo"
                          Margin="0" />

                <StackPanel Grid.Column="3"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom"
                            Margin="10,0,0,0">
                    <Button Command="{Binding LimparSelecaoCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Width="50"
                            Margin="0,0,10,0"
                            ToolTip="Limpar Seleção">
                        <mah:PackIconMaterial Kind="Refresh" />
                    </Button>

                    <Button Command="{Binding CompararCommand}"
                            Style="{StaticResource ModernButtonStyle}"
                            Margin="0,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <mah:PackIconMaterial Kind="ScaleBalance"
                                                  Margin="0,0,10,0"
                                                  VerticalAlignment="Center" />
                            <TextBlock Text="Comparar" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Estado Vazio -->
        <Grid Grid.Row="2"
              Visibility="{Binding TemResultado, Converter={StaticResource InverseBoolToVis}}"
              VerticalAlignment="Center"
              HorizontalAlignment="Center"
              Opacity="0.5">
            <StackPanel HorizontalAlignment="Center">
                <mah:PackIconMaterial Kind="FileCompare"
                                      Width="64"
                                      Height="64"
                                      HorizontalAlignment="Center"
                                      Foreground="{DynamicResource TextPrimaryBrush}" />
                <TextBlock Text="Selecione dois editais acima para iniciar a análise"
                           Margin="0,20,0,0"
                           FontSize="16"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource TextPrimaryBrush}" />
            </StackPanel>
        </Grid>

        <!-- Conteúdo -->
        <ScrollViewer Grid.Row="2"
                      Visibility="{Binding TemResultado, Converter={StaticResource BoolToVis}}"
                      Style="{DynamicResource ModernScrollViewerStyle}"
                      Margin="0"
                      VerticalScrollBarVisibility="Visible">
            <StackPanel>

                <Grid Margin="20,10,5,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource PrimaryCardStyle}"
                            Margin="0,0,5,0"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Afinidade de Conteúdo"
                                           Style="{StaticResource Title3Style}" />
                                <TextBlock Text="Quanto do edital alvo já está coberto?"
                                           Style="{StaticResource Text2Style}"
                                           FontSize="12" />
                            </StackPanel>

                            <controls:AccuracyPieChartControl Grid.Row="1"
                                                              Height="220"
                                                              Margin="0,20"
                                                              Dados="{Binding DadosGraficoAfinidade, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Grid.Row="2"
                                       Text="{Binding Resultado.PercentualCompatibilidade, StringFormat='{}{0:N1}% Compatível'}"
                                       HorizontalAlignment="Center"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Foreground="{DynamicResource PrimaryBrush}" />
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource PrimaryCardStyle}"
                            Margin="5,0,0,0"
                            Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Cenário Real"
                                           Style="{StaticResource Title3Style}" />
                                <TextBlock Text="Sua situação atual considerando o que já estudou."
                                           Style="{StaticResource Text2Style}"
                                           FontSize="12" />
                            </StackPanel>

                            <controls:AccuracyPieChartControl Grid.Row="1"
                                                              Height="220"
                                                              Margin="0,20"
                                                              Dados="{Binding DadosGraficoConquista, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" />

                            <StackPanel Grid.Row="2"
                                        HorizontalAlignment="Center"
                                        Orientation="Horizontal">
                                <mah:PackIconMaterial Kind="Target"
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,5,0"
                                                      Foreground="{DynamicResource SuccessBrush}" />
                                <TextBlock Text="{Binding Resultado.PercentualJaConcluidoDoAlvo, StringFormat='{}{0:N1}% Concluído'}"
                                           FontWeight="Bold"
                                           FontSize="16"
                                           Foreground="{DynamicResource SuccessBrush}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Style="{StaticResource PrimaryCardStyle}"
                        Margin="20,10,5,10"
                        Padding="0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Background="{DynamicResource PrimaryBrush}"
                                CornerRadius="8,8,0,0"
                                Padding="20">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Oportunidades de Conciliação"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               FontSize="16" />
                                    <TextBlock Text="Assuntos comuns aos dois editais que você AINDA NÃO estudou. Prioridade Máxima!"
                                               Foreground="White"
                                               Opacity="0.8"
                                               Margin="0,5,0,0" />
                                </StackPanel>
                                <mah:PackIconMaterial Grid.Column="1"
                                                      Kind="StarCircle"
                                                      Width="30"
                                                      Height="30"
                                                      Foreground="White"
                                                      Opacity="0.8" />
                            </Grid>
                        </Border>

                        <ListView Grid.Row="1"
                                  ItemsSource="{Binding Resultado.AssuntosConciliaveisPendentes}"
                                  BorderThickness="0"
                                  MaxHeight="300"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto">

                            <ListView.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryBrush}"
                                                       Margin="15,15,0,5" />
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListView.GroupStyle>

                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <mah:PackIconMaterial Kind="CheckboxBlankCircleOutline"
                                                              Foreground="Gray"
                                                              VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Nome}"
                                                   FontSize="14"
                                                   VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <TextBlock Grid.Row="1"
                                   Text="Nenhum assunto pendente comum. Parabéns!"
                                   HorizontalAlignment="Center"
                                   Padding="20"
                                   FontStyle="Italic"
                                   Visibility="{Binding Resultado.AssuntosConciliaveisPendentes.Count, Converter={StaticResource CountToVisibilityConverter}, ConverterParameter=Invert}" />
                    </Grid>
                </Border>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Background="#FFF3E0"
                            BorderBrush="#FFB74D"
                            BorderThickness="1"
                            CornerRadius="4"
                            Padding="15"
                            Margin="20,10,5,5">
                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Center">
                            <mah:PackIconMaterial Kind="ClockAlert"
                                                  Width="24"
                                                  Height="24"
                                                  Foreground="#F57C00"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,10,0" />
                            <TextBlock Text="{Binding Resultado.MensagemEstrategicaTempo}"
                                       Foreground="#E65100"
                                       FontWeight="Bold"
                                       FontSize="15"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource PrimaryCardStyle}"
                                Margin="20,10,5,10"
                                Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Padding="15"
                                        CornerRadius="8,8,0,0"
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="#EEEEEE">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Resultado.IsBasePrioritaria}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="#FFF3E0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Resultado.EditalBase.Orgao}"
                                                   FontWeight="Bold"
                                                   FontSize="16" />
                                        <TextBlock Text="Exclusivos deste edital"
                                                   FontSize="12"
                                                   Opacity="0.6" />
                                    </StackPanel>
                                </Border>

                                <ListView Grid.Row="1"
                                          ItemsSource="{Binding Resultado.AssuntosExclusivosBase}"
                                          BorderThickness="0"
                                          MaxHeight="300"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Nome}"
                                                       Margin="5" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource PrimaryCardStyle}"
                                Margin="10,10,5,10"
                                Padding="0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <Border Padding="15"
                                        CornerRadius="8,8,0,0"
                                        BorderThickness="0,0,0,1"
                                        BorderBrush="#EEEEEE">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"
                                                    Value="Transparent" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Resultado.IsAlvoPrioritario}"
                                                             Value="True">
                                                    <Setter Property="Background"
                                                            Value="#FFF3E0" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Resultado.EditalAlvo.Orgao}"
                                                   FontWeight="Bold"
                                                   FontSize="16" />
                                        <TextBlock Text="Exclusivos deste edital"
                                                   FontSize="12"
                                                   Opacity="0.6" />
                                    </StackPanel>
                                </Border>

                                <ListView Grid.Row="1"
                                          ItemsSource="{Binding Resultado.AssuntosExclusivosAlvoPendentes}"
                                          BorderThickness="0"
                                          MaxHeight="300"
                                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                                    <ListView.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Nome}"
                                                       Margin="5" />
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <Border Height="50" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>